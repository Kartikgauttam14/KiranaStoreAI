{
  "name": "@kiranaai/backend",
  "version": "1.0.0",
  "description": "KiranaAI Backend API",
  "main": "src/index.ts",
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "watch": "ts-node-dev -r tsconfig-paths/register --respawn src/index.ts",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "seed": "ts-node --require tsconfig-paths/register prisma/seed.ts",
    "studio": "prisma studio",
    "generate": "prisma generate",
    "reset": "prisma migrate reset"
  },
  "keywords": [
    "express",
    "typescript",
    "kirana",
    "inventory"
  ],
  "author": "Kirana AI",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.16.0",
    "@prisma/client": "^5.13.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.0",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.6",
    "prisma": "^5.13.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
